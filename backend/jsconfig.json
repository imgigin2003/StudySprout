{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2022",
    "checkJs": false,
    "allowJs": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "moduleResolution": "node",
    "maxNodeModuleJsDepth": 0,
    "lib": ["es2022"]
  },
  "exclude": ["node_modules", "frontend", "public", "dist"]
}
